			},
			{
				"command": "esp.otaRead",
				"title": "ESP › OTA Read Status",
				"icon": "$(eye)"
			},
			{
				"command": "esp.otaErase",
				"title": "ESP › OTA Erase Partition",
				"icon": "$(trash)"
