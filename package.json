			},
			{
				"command": "esp.selectFlashBaud",
				"title": "ESP › Select Flash Baud Rate"
			},
			{
				"command": "esp.selectIdf",
				"title": "ESP › Select IDF Path"
			},
			{
				"command": "esp.selectProject",
				"title": "ESP › Select Project"
			},
			{
				"command": "esp.toggleOverride",
				"title": "ESP › Toggle Flash Override"
			},
			{
				"command": "esp.selectFlashMode",
				"title": "ESP › Select Flash Mode"
			},
			{
				"command": "esp.selectFlashFreq",
				"title": "ESP › Select Flash Frequency"
			},
			{
				"command": "esp.selectFlashSize",
				"title": "ESP › Select Flash Size"
			},
			{
				"command": "esp.toggleCompressedUpload",
				"title": "ESP › Toggle Compressed Upload"
			},
			{
				"command": "esp.selectBeforeFlashing",
				"title": "ESP › Select Chip Reset Before Flash (esptool --before)"
			},
			{
				"command": "esp.selectAfterFlashing",
				"title": "ESP › Select Chip Reset After Flash (esptool --after)"
			},
			{
				"command": "esp.configureBuild",
				"title": "ESP › Configure Build Actions",
				"icon": "$(checklist)"
			},
			{
				"command": "esp.configureFlash",
				"title": "ESP › Configure Flash Actions",
				"icon": "$(checklist)"
			},
			{
				"command": "esp.refreshViews",
				"title": "ESP › Refresh",
				"icon": "$(refresh)"
			},
			{
				"command": "esp.collapseAll",
				"title": "ESP › Collapse All",
				"icon": "$(collapse-all)"
			},
			{
				"command": "esp.partitionEditor",
				"title": "ESP › Partition Table Editor"
			},
			{
				"command": "esp.otaFlash",
				"title": "ESP › OTA Flash (Write firmware to OTA slot)",
				"icon": "$(cloud-upload)"
			},
			{
				"command": "esp.otaSwitch",
				"title": "ESP › OTA Switch (Change boot partition)",
