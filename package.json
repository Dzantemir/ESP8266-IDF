{
	"name": "esp8266-idf",
	"displayName": "ESP8266-IDF",
	"description": "Build, flash, monitor and configure ESP8266-series projects (ESP8266, ESP8285) using ESP8266_RTOS_SDK (idf.py). Supports Windows, Linux and macOS.",
	"version": "1.85.1",
	"publisher": "Dzantemir",
	"author": "Dzantemir",
	"license": "MIT",
	"engines": {
		"vscode": "^1.75.0"
	},
	"categories": [
		"Other",
		"Debuggers",
		"Programming Languages"
	],
	"keywords": [
		"esp8266",
		"esp8285",
		"espressif",
		"iot",
		"embedded",
		"rtos",
		"idf",
		"idf.py",
		"flash",
		"serial",
		"monitor",
		"menuconfig",
		"partition",
		"firmware",
		"microcontroller",
		"littlefs",
		"filesystem"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/Dzantemir/ESP8266-IDF.git"
	},
	"bugs": {
		"url": "https://github.com/Dzantemir/ESP8266-IDF/issues"
	},
	"homepage": "https://github.com/Dzantemir/ESP8266-IDF#readme",
	"icon": "media/icon.png",
	"activationEvents": [
		"onView:esp8266-idf.projectView",
		"workspaceContains:sdkconfig",
		"workspaceContains:CMakeLists.txt",
		"onCommand:esp.build",
		"onCommand:esp.flash",
		"onCommand:esp.monitor",
		"onCommand:esp.partitionEditor",
		"onCommand:esp.otaFlash",
		"onCommand:esp.flashFileSystem",
		"onCommand:esp.createProject"
	],
	"main": "./src/extension.js",
	"contributes": {
		"problemMatchers": [
			{
				"name": "esp-idf-gcc",
				"owner": "cpp",
				"fileLocation": [
					"relative",
					"${workspaceFolder}"
				],
				"pattern": {
					"regexp": "^(.*):(\\d+):(\\d+):\\s+(warning|error):\\s+(.*)$",
					"file": 1,
					"line": 2,
					"column": 3,
					"severity": 4,
					"message": 5
				}
			}
		],
		"viewsContainers": {
			"activitybar": [
				{
					"id": "esp8266-idf-explorer",
					"title": "ESP8266-IDF",
					"icon": "media/icon_mono.svg"
				}
			]
		},
		"views": {
			"esp8266-idf-explorer": [
				{
					"id": "esp8266-idf.projectView",
					"name": "Project & Commands",
					"icon": "media/icon_mono.svg"
				}
			]
		},
		"commands": [
			{
				"command": "esp.build",
				"title": "ESP › Build"
			},
			{
				"command": "esp.buildApp",
				"title": "ESP › Build App"
			},
			{
				"command": "esp.buildBootloader",
				"title": "ESP › Build Bootloader"
			},
			{
				"command": "esp.buildPartition",
				"title": "ESP › Build Partition Table"
			},
			{
				"command": "esp.size",
				"title": "ESP › Size"
			},
			{
				"command": "esp.sizeComponents",
				"title": "ESP › Size Components"
			},
			{
				"command": "esp.sizeFiles",
				"title": "ESP › Size Files"
			},
			{
				"command": "esp.menuconfig",
				"title": "ESP › Menuconfig"
			},
			{
